  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.54.0",
    "@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@types/node": "^24.0.0",
    "prettier": "^3.6.0",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte-check": "^4.2.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
